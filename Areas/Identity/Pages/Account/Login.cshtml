@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = "_AuthLayout";
}

<div class="auth-container">
    <div class="auth-header">
        <h1>Welcome Back</h1>
        <p>Log in to access your LMS portal</p>
    </div>

    <form id="account" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
            <label asp-for="Input.Email">Email Address</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>
        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
            <label asp-for="Input.Password">Password</label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>
        <div class="checkbox mb-3 d-flex justify-content-between align-items-center">
            <label asp-for="Input.RememberMe" class="form-label mb-0">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                @Html.DisplayNameFor(m => m.Input.RememberMe)
            </label>
            <a id="forgot-password" asp-page="./ForgotPassword" class="small text-decoration-none">Forgot?</a>
        </div>
        <div>
            <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary mb-3">Log in</button>
        </div>
    </form>

    @{
        if ((Model.ExternalLogins?.Count ?? 0) > 0)
        {
            <div class="divider">or continue with</div>
            <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div class="d-grid gap-2">
                    @foreach (var provider in Model.ExternalLogins!)
                    {
                        <button type="submit" class="btn btn-outline-secondary" name="provider" value="@provider.Name">@provider.DisplayName</button>
                    }
                </div>
            </form>
        }
    }

    <div class="auth-footer">
        Don't have an account? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create One</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
