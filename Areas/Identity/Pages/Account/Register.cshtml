@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = "_AuthLayout";
}

<div class="auth-container auth-register-container">
    <div class="auth-header">
        <h1>Join LMS</h1>
        <p>Create your employee account to get started</p>
    </div>

    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        
        <h5 class="mb-3 fw-bold text-primary">Account Security</h5>
        <div class="row">
            <div class="col-md-12">
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email Address</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.ConfirmPassword">Confirm Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>
            </div>
        </div>

        <h5 class="mt-2 mb-3 fw-bold text-primary">Personal Information</h5>
        <div class="row">
            <div class="col-md-6">
                <div class="form-floating mb-3">
                    <input asp-for="Input.FirstName" class="form-control" aria-required="true" placeholder="First Name" />
                    <label asp-for="Input.FirstName">First Name</label>
                    <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating mb-3">
                    <input asp-for="Input.LastName" class="form-control" aria-required="true" placeholder="Last Name" />
                    <label asp-for="Input.LastName">Last Name</label>
                    <span asp-validation-for="Input.LastName" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating mb-3">
                    <input asp-for="Input.EmployeeCode" class="form-control" placeholder="Employee Code" />
                    <label asp-for="Input.EmployeeCode">Employee Code (Optional)</label>
                    <span asp-validation-for="Input.EmployeeCode" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-floating mb-3">
                    <input asp-for="Input.DateJoined" class="form-control" type="date" aria-required="true" />
                    <label asp-for="Input.DateJoined">Joining Date</label>
                    <span asp-validation-for="Input.DateJoined" class="text-danger"></span>
                </div>
            </div>
        </div>

        <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary mb-3 mt-2">Create Account</button>
    </form>

    <div class="auth-footer">
        Already have an account? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Sign In Instead</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
