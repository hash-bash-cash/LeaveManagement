@model LMS.Models.Holiday
@{
    ViewData["Title"] = "Add Holiday";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h2><i class="bi bi-plus-circle me-2" style="color:#6366f1"></i>Add Holiday</h2>
    <p>Add a new company holiday to the calendar</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4">
                <form asp-action="AddHoliday" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2" style="display:none"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Holiday Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Independence Day" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Date" class="form-label fw-semibold">Date <span class="text-danger">*</span></label>
                        <input asp-for="Date" type="date" class="form-control" required />
                        <span asp-validation-for="Date" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <input asp-for="IsRecurringYearly" class="form-check-input" type="checkbox" checked />
                            <label asp-for="IsRecurringYearly" class="form-check-label fw-semibold">
                                Recurring Yearly
                                <span class="text-muted fw-normal" style="font-size:0.82rem">(e.g. national holidays that repeat every year)</span>
                            </label>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn" style="background:#6366f1; color:#fff;">
                            <i class="bi bi-check-circle me-1"></i> Add Holiday
                        </button>
                        <a asp-action="HolidayCalendar" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
