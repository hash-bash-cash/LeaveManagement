@model List<LMS.Models.AdminLeaveRequestViewModel>
@{
    ViewData["Title"] = "All Leave Requests";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h2><i class="bi bi-list-ul me-2" style="color:#6366f1"></i>All Leave Requests</h2>
        <p>Complete list of all employee leave requests across the organization</p>
    </div>
    <span class="badge rounded-pill" style="background:#ede9fe; color:#6366f1; font-size:0.85rem; padding:8px 16px;">
        @Model.Count total
    </span>
</div>

@await Html.PartialAsync("_LeaveRequestsTable", Model)
