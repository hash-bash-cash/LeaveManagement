@model List<LMS.Models.AdminLeaveRequestViewModel>
@{
    ViewData["Title"] = "Approved Leaves";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h2><i class="bi bi-check-circle me-2" style="color:#059669"></i>Approved Leaves</h2>
        <p>All approved leave requests across the organization</p>
    </div>
    <span class="badge rounded-pill" style="background:#d1fae5; color:#065f46; font-size:0.85rem; padding:8px 16px;">
        @Model.Count approved
    </span>
</div>

@await Html.PartialAsync("_LeaveRequestsTable", Model)
