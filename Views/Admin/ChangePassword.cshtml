@model LMS.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4 pb-0">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-2">
                        <li class="breadcrumb-item small"><a asp-action="Profile" class="text-decoration-none">Profile</a></li>
                        <li class="breadcrumb-item active small" aria-current="page">Security</li>
                    </ol>
                </nav>
                <h4 class="fw-bold mb-0 text-dark"><i class="bi bi-shield-lock me-2 text-primary"></i>Update Security Credentials</h4>
                <p class="text-muted small mt-2">Ensure your account stays secure by using a strong password at least 6 characters long.</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 small rounded-3" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="OldPassword" class="form-control" placeholder="Current Password" />
                        <label asp-for="OldPassword">Current Password</label>
                        <span asp-validation-for="OldPassword" class="text-danger small"></span>
                    </div>

                    <hr class="my-4 opacity-50">

                    <div class="form-floating mb-3">
                        <input asp-for="NewPassword" class="form-control" placeholder="New Password" />
                        <label asp-for="NewPassword">New Password</label>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm New Password" />
                        <label asp-for="ConfirmPassword">Confirm New Password</label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm rounded-3 py-2 fw-bold">
                            Update Security Settings
                        </button>
                        <a asp-action="Profile" class="btn btn-light btn-sm mt-2 border-0">Cancel and Return</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="alert bg-soft-primary border-0 rounded-4 mt-4 p-4 d-flex align-items-start">
            <i class="bi bi-info-circle-fill text-primary fs-4 me-3 mt-1"></i>
            <div>
                <h6 class="fw-bold text-primary mb-1">Security Best Practices</h6>
                <ul class="mb-0 small text-muted ps-3">
                    <li>Use a mix of uppercase and lowercase letters.</li>
                    <li>Include at least one numerical digit and one special character (!, @@, #).</li>
                    <li>Avoid using common words or personal information like birthdays.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary { background-color: rgba(99, 102, 241, 0.1); }
    .form-control:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 0.25rem rgba(79, 70, 229, 0.15);
    }
    .rounded-4 { border-radius: 1.25rem !important; }
    .breadcrumb-item + .breadcrumb-item::before { content: "›"; font-size: 1.2rem; line-height: 1; vertical-align: middle; }
</style>
