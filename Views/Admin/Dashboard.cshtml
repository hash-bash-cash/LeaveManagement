@model LMS.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h2><i class="bi bi-speedometer2 me-2" style="color:#6366f1"></i>Admin Dashboard</h2>
    <p>System overview and analytics for @DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
</div>

<!-- STAT CARDS ROW 1 -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#ede9fe">
                <i class="bi bi-people-fill" style="color:#6366f1"></i>
            </div>
            <div>
                <div class="stat-value">@Model.TotalEmployees</div>
                <div class="stat-label">Total Employees</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#dbeafe">
                <i class="bi bi-person-badge-fill" style="color:#2563eb"></i>
            </div>
            <div>
                <div class="stat-value">@Model.TotalManagers</div>
                <div class="stat-label">Total Managers</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef3c7">
                <i class="bi bi-hourglass-split" style="color:#d97706"></i>
            </div>
            <div>
                <div class="stat-value">@Model.PendingApprovals</div>
                <div class="stat-label">Pending Approvals</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#d1fae5">
                <i class="bi bi-check-circle-fill" style="color:#059669"></i>
            </div>
            <div>
                <div class="stat-value">@Model.ActiveLeaveRequests</div>
                <div class="stat-label">Active Leave Requests</div>
            </div>
        </div>
    </div>
</div>

<!-- STAT CARDS ROW 2 -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fce7f3">
                <i class="bi bi-diagram-3-fill" style="color:#db2777"></i>
            </div>
            <div>
                <div class="stat-value">@Model.TotalDepartments</div>
                <div class="stat-label">Departments</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#e0f2fe">
                <i class="bi bi-grid-3x3-gap-fill" style="color:#0284c7"></i>
            </div>
            <div>
                <div class="stat-value">@Model.TotalTeams</div>
                <div class="stat-label">Teams</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fee2e2">
                <i class="bi bi-person-x-fill" style="color:#dc2626"></i>
            </div>
            <div>
                <div class="stat-value">@Model.EmployeesOnLeaveToday</div>
                <div class="stat-label">On Leave Today</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon" style="background:#f0fdf4">
                <i class="bi bi-calendar-event-fill" style="color:#16a34a"></i>
            </div>
            <div>
                <div class="stat-value">@Model.UpcomingHolidays</div>
                <div class="stat-label">Upcoming Holidays</div>
            </div>
        </div>
    </div>
</div>

<!-- BOTTOM ROW -->
<div class="row g-4">
    <!-- Employees On Leave Today -->
    <div class="col-lg-7">
        <div class="admin-table">
            <div style="padding: 18px 20px; border-bottom: 1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
                <h6 class="mb-0 fw-bold"><i class="bi bi-person-x me-2 text-danger"></i>Employees On Leave Today</h6>
            </div>
            @if (Model.EmployeesOnLeaveTodayList.Any())
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Leave Type</th>
                            <th>End Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var leave in Model.EmployeesOnLeaveTodayList)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@leave.RequestingEmployee?.FirstName @leave.RequestingEmployee?.LastName</div>
                                    <div class="text-muted" style="font-size:0.78rem">@leave.RequestingEmployee?.Email</div>
                                </td>
                                <td><span class="badge bg-primary bg-opacity-10 text-primary">@leave.LeaveType?.Name</span></td>
                                <td>@leave.EndDate.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-check-circle" style="font-size:2.5rem; opacity:0.3"></i>
                    <p class="mt-2 mb-0">No employees are on leave today</p>
                </div>
            }
        </div>
    </div>

    <!-- Upcoming Holidays -->
    <div class="col-lg-5">
        <div class="admin-table">
            <div style="padding: 18px 20px; border-bottom: 1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
                <h6 class="mb-0 fw-bold"><i class="bi bi-calendar2-event me-2 text-success"></i>Upcoming Holidays</h6>
                <a asp-controller="Admin" asp-action="HolidayCalendar" class="btn btn-sm btn-outline-primary" style="font-size:0.78rem">View All</a>
            </div>
            @if (Model.UpcomingHolidayList.Any())
            {
                <div style="padding: 8px 0;">
                    @foreach (var h in Model.UpcomingHolidayList)
                    {
                        var daysLeft = (h.Date - DateTime.Today).Days;
                        <div style="padding: 12px 20px; border-bottom: 1px solid #f1f5f9; display:flex; justify-content:space-between; align-items:center;">
                            <div>
                                <div class="fw-semibold" style="font-size:0.9rem">@h.Name</div>
                                <div class="text-muted" style="font-size:0.78rem">@h.Date.ToString("dd MMM yyyy")</div>
                            </div>
                            <span class="badge" style="background:#f0fdf4; color:#16a34a; font-size:0.75rem">
                                @(daysLeft == 0 ? "Today" : daysLeft == 1 ? "Tomorrow" : $"In {daysLeft} days")
                            </span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-calendar-x" style="font-size:2rem; opacity:0.3"></i>
                    <p class="mt-2 mb-0">No upcoming holidays</p>
                </div>
            }
        </div>
    </div>
</div>
