@model List<LMS.Models.LeaveRequest>
@{
    ViewData["Title"] = "Employee Leave History";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var employee = ViewBag.Employee as LMS.Models.ApplicationUser;
}

<div class="page-header">
    <h2><i class="bi bi-clock-history me-2" style="color:#6366f1"></i>Employee Leave History</h2>
    <p>Complete leave history for a specific employee</p>
</div>

@if (employee != null)
{
    <div class="card border-0 shadow-sm rounded-3 mb-4" style="background: linear-gradient(135deg, #6366f1, #8b5cf6); color:#fff;">
        <div class="card-body p-4">
            <div class="d-flex align-items-center gap-4">
                <div style="width:64px; height:64px; border-radius:50%; background:rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center; font-size:1.8rem; font-weight:800;">
                    @employee.FirstName[0]@employee.LastName[0]
                </div>
                <div>
                    <h4 class="mb-1 fw-bold">@employee.FirstName @employee.LastName</h4>
                    <div style="opacity:0.85; font-size:0.88rem">
                        <i class="bi bi-envelope me-1"></i>@employee.Email
                        @if (!string.IsNullOrEmpty(employee.EmployeeCode))
                        {
                            <span class="ms-3"><i class="bi bi-tag me-1"></i>@employee.EmployeeCode</span>
                        }
                        @if (!string.IsNullOrEmpty(employee.Shift))
                        {
                            <span class="ms-3"><i class="bi bi-clock me-1"></i>@employee.Shift</span>
                        }
                    </div>
                </div>
                <div class="ms-auto text-end">
                    <div style="font-size:2rem; font-weight:800;">@Model.Count</div>
                    <div style="opacity:0.85; font-size:0.82rem">Total Requests</div>
                </div>
            </div>
        </div>
    </div>
}

<div class="admin-table">
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:3rem; opacity:0.3"></i>
            <p class="mt-3">No leave history found for this employee.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Leave Type</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Days</th>
                        <th>Applied On</th>
                        <th>Status</th>
                        <th>Manager Remarks</th>
                        <th>Reviewed By</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var status = r.Cancelled ? "Cancelled" : r.Approved == null ? "Pending" : r.Approved == true ? "Approved" : "Rejected";
                        var badgeCss = status switch { "Approved" => "badge-approved", "Rejected" => "badge-rejected", "Cancelled" => "badge-cancelled", _ => "badge-pending" };
                        <tr>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary">@r.LeaveType?.Name</span></td>
                            <td>@r.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@r.EndDate.ToString("dd MMM yyyy")</td>
                            <td class="fw-bold">@((int)(r.EndDate - r.StartDate).TotalDays + 1)</td>
                            <td style="font-size:0.82rem">@r.DateRequested.ToString("dd MMM yyyy")</td>
                            <td><span class="badge @badgeCss" style="padding:5px 10px; border-radius:20px;">@status</span></td>
                            <td style="font-size:0.82rem; max-width:180px">@(r.ManagerRemarks ?? "—")</td>
                            <td style="font-size:0.82rem">
                                @if (r.Reviewer != null)
                                {
                                    @($"{r.Reviewer.FirstName} {r.Reviewer.LastName}")
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="mt-3">
    <a asp-controller="Admin" asp-action="AllLeaveRequests" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to All Requests
    </a>
</div>
