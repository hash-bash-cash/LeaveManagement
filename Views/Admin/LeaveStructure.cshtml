@model List<LMS.Models.LeaveType>
@{
    ViewData["Title"] = "Leave Structure";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h2><i class="bi bi-journal-text me-2" style="color:#6366f1"></i>Leave Structure</h2>
    <p>Company leave types and their policy rules. Click Edit to modify rules for any leave type.</p>
</div>

<div class="admin-table">
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Code</th>
                    <th>Default Days</th>
                    <th>Max Consecutive</th>
                    <th>Yearly Limit</th>
                    <th>Paid</th>
                    <th>Requires Approval</th>
                    <th>Carry Forward</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox" style="font-size:2rem; opacity:0.3"></i>
                            <p class="mb-0 mt-2">No leave types configured yet.</p>
                        </td>
                    </tr>
                }
                @foreach (var lt in Model)
                {
                    <tr>
                        <td class="fw-semibold">@lt.Name</td>
                        <td>
                            @if (!string.IsNullOrEmpty(lt.Code))
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary fw-bold" style="font-family:monospace">@lt.Code</span>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td><span class="fw-bold text-primary">@lt.DefaultDays</span> days</td>
                        <td>@(lt.MaxConsecutiveDays > 0 ? $"{lt.MaxConsecutiveDays} days" : "No limit")</td>
                        <td>@(lt.YearlyLimit > 0 ? $"{lt.YearlyLimit} days" : "Unlimited")</td>
                        <td>
                            @if (lt.IsPaid)
                            {
                                <span class="badge badge-approved" style="border-radius:20px; padding:5px 10px"><i class="bi bi-check me-1"></i>Yes</span>
                            }
                            else
                            {
                                <span class="badge badge-rejected" style="border-radius:20px; padding:5px 10px"><i class="bi bi-x me-1"></i>No</span>
                            }
                        </td>
                        <td>
                            @if (lt.RequiresApproval)
                            {
                                <span class="badge badge-pending" style="border-radius:20px; padding:5px 10px">Required</span>
                            }
                            else
                            {
                                <span class="badge badge-cancelled" style="border-radius:20px; padding:5px 10px">Auto</span>
                            }
                        </td>
                        <td>
                            @if (lt.CarryForward)
                            {
                                <span class="badge badge-approved" style="border-radius:20px; padding:5px 10px"><i class="bi bi-arrow-repeat me-1"></i>Yes</span>
                            }
                            else
                            {
                                <span class="badge badge-cancelled" style="border-radius:20px; padding:5px 10px">No</span>
                            }
                        </td>
                        <td>
                            @if (lt.IsEnabled)
                            {
                                <span class="badge badge-approved" style="border-radius:20px; padding:5px 10px"><i class="bi bi-power me-1"></i>Active</span>
                            }
                            else
                            {
                                <span class="badge badge-rejected" style="border-radius:20px; padding:5px 10px">Disabled</span>
                            }
                        </td>
                        <td>
                            <a asp-action="EditLeaveType" asp-route-id="@lt.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil me-1"></i> Edit Rules
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3">
    <div class="alert alert-info py-2" style="font-size:0.83rem; border-radius:10px;">
        <i class="bi bi-info-circle me-1"></i>
        <strong>Note:</strong> Leave types represent company policy. You can edit rules but cannot delete them to preserve historical data integrity.
        To disable a leave type, uncheck "Enabled" when editing.
    </div>
</div>
