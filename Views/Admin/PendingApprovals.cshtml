@model List<LMS.Models.AdminLeaveRequestViewModel>
@{
    ViewData["Title"] = "Pending Approvals";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h2><i class="bi bi-hourglass-split me-2" style="color:#d97706"></i>Pending Approvals</h2>
        <p>Leave requests awaiting manager approval</p>
    </div>
    @if (Model.Any())
    {
        <span class="badge rounded-pill" style="background:#fef3c7; color:#92400e; font-size:0.85rem; padding:8px 16px;">
            @Model.Count pending
        </span>
    }
</div>

@await Html.PartialAsync("_LeaveRequestsTable", Model)
