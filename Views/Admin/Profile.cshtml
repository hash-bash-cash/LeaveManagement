@model LMS.Models.ApplicationUser
@{
    ViewData["Title"] = "Admin Profile";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var initials = (Model.FirstName?[..1] ?? "A") + (Model.LastName?[..1] ?? "");
}

<div class="row">
    <div class="col-lg-4">
        <!-- Profile Card -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body text-center p-5">
                <div class="profile-avatar mb-3 mx-auto">@initials</div>
                <h4 class="fw-bold mb-1">@Model.FirstName @Model.LastName</h4>
                <p class="text-muted mb-3">System Administrator</p>
                <div class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2">
                    <i class="bi bi-patch-check-fill me-1"></i> Active Session
                </div>
            </div>
        </div>

        <!-- Quick Access -->
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-transparent border-0 pt-4 px-4">
                <h6 class="fw-bold mb-0">System Privileges</h6>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-shield-check text-primary fs-5 me-3"></i>
                    <div>
                        <div class="fw-bold small">Full Access</div>
                        <div class="text-muted" style="font-size: 0.75rem;">Manage all users and system settings</div>
                    </div>
                </div>
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-database-check text-success fs-5 me-3"></i>
                    <div>
                        <div class="fw-bold small">Database Management</div>
                        <div class="text-muted" style="font-size: 0.75rem;">Modify core system data & models</div>
                    </div>
                </div>
                <div class="d-flex align-items-center">
                    <i class="bi bi-send-check text-info fs-5 me-3"></i>
                    <div>
                        <div class="fw-bold small">Broadcast Alerts</div>
                        <div class="text-muted" style="font-size: 0.75rem;">Notify all employees instantly</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="card-header bg-white border-bottom-0 pt-4 px-4">
                <h5 class="fw-bold mb-0"><i class="bi bi-person-lines-fill me-2 text-primary"></i>Administrative Account Details</h5>
            </div>
            <div class="card-body p-4">
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">First Name</label>
                        <p class="form-control-plaintext border-bottom pb-2">@Model.FirstName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Last Name</label>
                        <p class="form-control-plaintext border-bottom pb-2">@Model.LastName</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Email Address</label>
                        <p class="form-control-plaintext border-bottom pb-2">@Model.Email</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Administrative ID</label>
                        <p class="form-control-plaintext border-bottom pb-2">@Model.Id.Substring(0, 8).ToUpper()</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Joined Platform</label>
                        <p class="form-control-plaintext border-bottom pb-2">@Model.DateJoined.ToString("dd MMMM yyyy")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Security Status</label>
                        <p class="form-control-plaintext border-bottom pb-2 text-success fw-bold"><i class="bi bi-lock-fill me-1"></i> Multi-factor Authenticated</p>
                    </div>
                </div>

                <div class="mt-4 pt-3 d-flex gap-2">
                    <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-primary shadow-sm px-4">
                        <i class="bi bi-pencil-square me-1"></i> Edit Account Info
                    </a>
                    <a asp-area="Identity" asp-page="/Account/Manage/ChangePassword" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-key me-1"></i> Change Password
                    </a>
                </div>
            </div>
        </div>

        <div class="alert alert-info border-0 shadow-sm rounded-4 d-flex align-items-center p-4">
            <i class="bi bi-info-circle-fill fs-3 me-3"></i>
            <div>
                <h6 class="fw-bold mb-1">Administrative Role Security</h6>
                <p class="mb-0 small">As an administrator, your account is protected with enterprise-level encryption and logging. All major system changes made by this account are audited in the system logs.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .profile-avatar {
        width: 100px; height: 100px;
        background: linear-gradient(135deg, var(--admin-accent), #4f46e5);
        color: #fff;
        border-radius: 24px;
        display: flex; align-items: center; justify-content: center;
        font-size: 2.2rem; font-weight: 800;
        box-shadow: 0 10px 25px rgba(99, 102, 241, 0.3);
        border: 4px solid #fff;
    }
    .rounded-4 { border-radius: 1.25rem !important; }
    .form-control-plaintext { font-weight: 500; color: #1e293b; font-size: 1rem; }
</style>
