@model List<LMS.Models.AdminLeaveRequestViewModel>
@{
    ViewData["Title"] = "Rejected Leaves";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h2><i class="bi bi-x-circle me-2" style="color:#dc2626"></i>Rejected Leaves</h2>
        <p>All rejected leave requests across the organization</p>
    </div>
    <span class="badge rounded-pill" style="background:#fee2e2; color:#991b1b; font-size:0.85rem; padding:8px 16px;">
        @Model.Count rejected
    </span>
</div>

@await Html.PartialAsync("_LeaveRequestsTable", Model)
