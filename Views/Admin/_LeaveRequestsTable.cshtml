@model List<LMS.Models.AdminLeaveRequestViewModel>

@if (!Model.Any())
{
    <div class="admin-table">
        <div class="text-center py-5 text-muted">
            <i class="bi bi-inbox" style="font-size:3rem; opacity:0.3"></i>
            <p class="mt-3 mb-0 fw-semibold">No leave requests found</p>
        </div>
    </div>
}
else
{
    <div class="admin-table">
        <div style="padding:14px 20px; border-bottom:1px solid #e2e8f0;">
            <input type="text" id="searchInput" class="form-control form-control-sm" 
                   placeholder="Search by name, leave type..." style="max-width:320px">
        </div>
        <div class="table-responsive">
            <table class="table" id="leaveTable">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Leave Type</th>
                        <th>Duration</th>
                        <th>Days</th>
                        <th>Applied On</th>
                        <th>Status</th>
                        <th>Reviewed By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@r.EmployeeName</div>
                                <div class="text-muted" style="font-size:0.78rem">@r.EmployeeEmail</div>
                            </td>
                            <td><span class="badge bg-primary bg-opacity-10 text-primary">@r.LeaveTypeName</span></td>
                            <td>
                                <div style="font-size:0.85rem">@r.StartDate.ToString("dd MMM") – @r.EndDate.ToString("dd MMM yyyy")</div>
                            </td>
                            <td><span class="fw-bold">@r.TotalDays</span></td>
                            <td style="font-size:0.82rem">@r.DateRequested.ToString("dd MMM yyyy")</td>
                            <td>
                                @{
                                    var badge = r.Status switch {
                                        "Approved"  => "badge-approved",
                                        "Rejected"  => "badge-rejected",
                                        "Cancelled" => "badge-cancelled",
                                        _           => "badge-pending"
                                    };
                                    var icon = r.Status switch {
                                        "Approved"  => "bi-check-circle",
                                        "Rejected"  => "bi-x-circle",
                                        "Cancelled" => "bi-slash-circle",
                                        _           => "bi-hourglass-split"
                                    };
                                }
                                <span class="badge @badge" style="padding:6px 10px; border-radius:20px;">
                                    <i class="bi @icon me-1"></i>@r.Status
                                </span>
                            </td>
                            <td style="font-size:0.82rem">
                                @(r.ReviewerName ?? "—")
                                @if (r.DateActioned.HasValue)
                                {
                                    <div class="text-muted">@r.DateActioned.Value.ToString("dd MMM yyyy")</div>
                                }
                            </td>
                            <td>
                                <a asp-controller="Admin" asp-action="EmployeeLeaveHistory" asp-route-id="@r.EmployeeId"
                                   class="btn btn-sm btn-outline-secondary" title="View Employee History">
                                    <i class="bi bi-clock-history"></i>
                                </a>
                                @if (!string.IsNullOrEmpty(r.AttachmentPath))
                                {
                                    <a href="@r.AttachmentPath" target="_blank" class="btn btn-sm btn-outline-info ms-1" title="View Attachment">
                                        <i class="bi bi-paperclip"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script>
        document.getElementById('searchInput').addEventListener('keyup', function () {
            const val = this.value.toLowerCase();
            document.querySelectorAll('#leaveTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
            });
        });
    </script>
}
