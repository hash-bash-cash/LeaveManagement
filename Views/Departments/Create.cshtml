@model LMS.Models.Department
@{
    ViewData["Title"] = "New Department";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var allDepts = ViewBag.Departments as List<LMS.Models.Department>;
}

<div class="page-header">
    <h2><i class="bi bi-plus-circle me-2" style="color:#6366f1"></i>New Department</h2>
    <p>Create a new department or sub-department</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Department Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Engineering" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="Brief description of this department"></textarea>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ParentDepartmentId" class="form-label fw-semibold">Parent Department</label>
                        <select asp-for="ParentDepartmentId" class="form-select">
                            <option value="">— None (Top-level department) —</option>
                            @if (allDepts != null)
                            {
                                @foreach (var d in allDepts.Where(x => x.ParentDepartmentId == null))
                                {
                                    <option value="@d.Id">@d.Name</option>
                                }
                            }
                        </select>
                        <div class="form-text">Leave blank to create a top-level department</div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn" style="background:#6366f1; color:#fff;">
                            <i class="bi bi-check-circle me-1"></i> Create Department
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
