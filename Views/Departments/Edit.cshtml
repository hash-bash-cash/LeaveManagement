@model LMS.Models.Department
@{
    ViewData["Title"] = "Edit Department";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var allDepts = ViewBag.Departments as List<LMS.Models.Department>;
}

<div class="page-header">
    <h2><i class="bi bi-pencil me-2" style="color:#6366f1"></i>Edit Department</h2>
    <p>Update department details</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Department Name <span class="text-danger">*</span></label>
                        <input asp-for="Name" class="form-control" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ParentDepartmentId" class="form-label fw-semibold">Parent Department</label>
                        <select asp-for="ParentDepartmentId" class="form-select">
                            <option value="">— None (Top-level department) —</option>
                            @if (allDepts != null)
                            {
                                @foreach (var d in allDepts.Where(x => x.ParentDepartmentId == null && x.Id != Model.Id))
                                {
                                    <option value="@d.Id" selected="@(Model.ParentDepartmentId == d.Id ? "selected" : null)">@d.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn" style="background:#6366f1; color:#fff;">
                            <i class="bi bi-check-circle me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
