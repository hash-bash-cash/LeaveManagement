@model List<LMS.Models.Department>
@{
    ViewData["Title"] = "Organizational Structure";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var topLevel = Model.Where(d => d.ParentDepartmentId == null).ToList();
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-diagram-3 me-2" style="color:#6366f1"></i>Organizational Structure</h2>
        <p class="text-muted mb-0">Manage hierarchical departments, sub-departments, and operational teams.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Teams" asp-action="Index" class="btn btn-outline-secondary shadow-sm">
            <i class="bi bi-people me-1"></i> View All Teams
        </a>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle me-1"></i> Add Department
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-diagram-3" style="font-size:3.5rem; color:#cbd5e1"></i>
            <h5 class="mt-3 fw-bold">No Records Found</h5>
            <p class="text-muted">Start by creating your top-level organizational units.</p>
            <a asp-action="Create" class="btn btn-primary mt-2 shadow-sm">Initialize Organization</a>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-12">
            @foreach (var dept in topLevel)
            {
                @await Html.PartialAsync("_DepartmentNode", dept)
            }
        </div>
    </div>
}

<style>
    .shadow-xs { box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    .dept-card { transition: all 0.2s ease; border-color: #e2e8f0 !important; }
    .dept-card:hover { transform: translateY(-2px); box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06) !important; border-color: #6366f1 !important; }
    .btn-group .btn { border-color: #edf2f7; }
</style>
