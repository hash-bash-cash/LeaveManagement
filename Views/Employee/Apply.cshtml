@model LMS.Models.ApplyLeaveViewModel
@{
    ViewData["Title"] = "Apply for Leave";
    Layout = User.IsInRole("Admin") ? "_AdminLayout" : (User.IsInRole("Manager") ? "_ManagerLayout" : "_EmployeeLayout");
}

<div class="row justify-content-center">
<div class="col-lg-8">
<div class="form-card">
    <h5 class="fw-bold mb-4"><i class="fa-solid fa-plus-circle me-2 text-primary"></i>New Leave Application</h5>

    <form asp-action="Apply" method="post" id="leaveForm" enctype="multipart/form-data">
        <div asp-validation-summary="All" class="alert alert-danger" style="display:none"></div>

        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                <ul class="mb-0">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@err.ErrorMessage</li>
                }
                </ul>
            </div>
        }

        <div class="row g-3">
            <div class="col-md-12">
                <label class="form-label fw-semibold">Leave Type *</label>
                <select asp-for="LeaveTypeId" class="form-select" required>
                    <option value="">— Select Leave Type —</option>
                    @foreach (var t in Model.LeaveTypes)
                    {
                        <option value="@t.Id">@t.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">Start Date *</label>
                <input asp-for="StartDate" type="date" class="form-control" id="startDate"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
            </div>

            <div class="col-md-6">
                <label class="form-label fw-semibold">End Date *</label>
                <input asp-for="EndDate" type="date" class="form-control" id="endDate"
                       min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
            </div>

            <div class="col-md-12">
                <div class="alert alert-info py-2 px-3 mb-0" id="daysSummary" style="display:none">
                    <i class="fa-solid fa-info-circle me-1"></i>
                    Total working days: <strong id="totalDays">0</strong>
                    <small class="text-muted ms-2">(weekends excluded)</small>
                </div>
            </div>

            <div class="col-md-12">
                <label class="form-label fw-semibold">Reason *</label>
                <textarea asp-for="Reason" class="form-control" rows="3"
                          placeholder="Briefly describe the reason for your leave..." required></textarea>
            </div>

            <!-- Bereavement Details Section -->
            <div id="bereavementSection" style="display:none" class="col-md-12">
                <div class="card bg-light border-0">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3 text-danger"><i class="fa-solid fa-heart me-2"></i>Bereavement Details</h6>
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-muted">Date of Death</label>
                                <input asp-for="DateOfDeath" class="form-control form-control-sm" type="date" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-muted">Deceased Name</label>
                                <input asp-for="DeceasedName" class="form-control form-control-sm" placeholder="Full Name" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold text-muted">Relationship</label>
                                <select asp-for="DeceasedRelationship" class="form-select form-select-sm" id="blRelation">
                                    <option value="">— Select Relation —</option>
                                    <optgroup label="Category A: Up to 5 days">
                                        <option value="Parent">Parent</option>
                                        <option value="Spouse">Spouse</option>
                                        <option value="Child">Child</option>
                                    </optgroup>
                                    <optgroup label="Category B: Up to 3 days">
                                        <option value="Brother">Brother</option>
                                        <option value="Sister">Sister</option>
                                        <option value="Grand Parent">Grand Parent</option>
                                        <option value="Grand Child">Grand Child</option>
                                        <option value="Father-in-law">Father-in-law</option>
                                        <option value="Mother-in-law">Mother-in-law</option>
                                        <option value="Son-in-law">Son-in-law</option>
                                        <option value="Daughter-in-law">Daughter-in-law</option>
                                    </optgroup>
                                    <optgroup label="Category C: 1 day">
                                        <option value="Brother-in-law">Brother-in-law</option>
                                        <option value="Sister-in-law">Sister-in-law</option>
                                        <option value="Spouse Grand Parent">Spouse’s Grand Parent</option>
                                    </optgroup>
                                </select>
                            </div>
                        </div>
                        <div id="blHint" class="alert alert-warning py-1 px-2 mt-2 small" style="display:none">
                            <i class="fa-solid fa-circle-exclamation me-1"></i> 
                            Max allowed for <span id="blRelationText"></span>: <strong id="blMaxDays"></strong> days.
                        </div>
                    </div>
                </div>
            </div>

            <!-- Floating Holiday Section -->
            <div id="floatingHolidaySection" style="display:none" class="col-md-12">
                <div class="card bg-soft-warning border-0 shadow-sm">
                    <div class="card-body">
                        <h6 class="fw-bold mb-3 text-warning-emphasis"><i class="fa-solid fa-star me-2"></i>Select Floating Holiday</h6>
                        <select id="floatingHolidaySelect" class="form-select border-warning">
                            <option value="">— Select Available Date —</option>
                            @foreach (var h in Model.AvailableFloatingHolidays)
                            {
                                <option value="@h.Date.ToString("yyyy-MM-dd")">@h.Name - @h.Date.ToString("dd MMM")</option>
                            }
                        </select>
                        <p class="mb-0 mt-2 small text-muted"><i class="fa-solid fa-info-circle me-1"></i> Selecting a holiday will automatically set the start and end dates.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-12">
                <label class="form-label fw-semibold">Supporting Document <span id="docRequired" class="text-danger" style="display:none">*</span></label>
                <input asp-for="Attachment" class="form-control" type="file" id="attachmentInput" />
                <div class="form-text mt-1 small">PDF, JPG, or PNG <span id="docHint">(e.g. Medical Certificate)</span></div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4">
                <i class="fa-solid fa-paper-plane me-1"></i> Submit Application
            </button>
            <a asp-action="History" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
</div>
</div>

@section Scripts {
<script>
function countBusinessDays(start, end) {
    let count = 0;
    let d = new Date(start);
    while (d <= end) {
        if (d.getDay() !== 0 && d.getDay() !== 6) count++;
        d.setDate(d.getDate() + 1);
    }
    return count;
}

function updateDays() {
    const s = document.getElementById('startDate').value;
    const e = document.getElementById('endDate').value;
    if (s && e && s <= e) {
        const days = countBusinessDays(new Date(s), new Date(e));
        document.getElementById('totalDays').textContent = days;
        document.getElementById('daysSummary').style.display = 'block';
    } else {
        document.getElementById('daysSummary').style.display = 'none';
    }
}

const leaveTypes = @Html.Raw(Json.Serialize(Model.LeaveTypes));

function updateUiForLeaveType() {
    const selectedId = document.getElementById('LeaveTypeId').value;
    const type = leaveTypes.find(t => t.id == selectedId);
    
    if (type) {
        // Bereavement Logic (BL)
        if (type.code === 'BL') {
            document.getElementById('bereavementSection').style.display = 'block';
            document.getElementById('DateOfDeath').required = true;
            document.getElementById('DeceasedName').required = true;
            document.getElementById('blRelation').required = true;
            updateBlHint();
        } else {
            document.getElementById('bereavementSection').style.display = 'none';
            document.getElementById('DateOfDeath').required = false;
            document.getElementById('DeceasedName').required = false;
            document.getElementById('blRelation').required = false;
            document.getElementById('blHint').style.display = 'none';
        }

        // Floating Holiday Logic (FD)
        if (type.code === 'FD') {
            document.getElementById('floatingHolidaySection').style.display = 'block';
            document.getElementById('startDate').readOnly = true;
            document.getElementById('endDate').readOnly = true;
        } else {
            document.getElementById('floatingHolidaySection').style.display = 'none';
            document.getElementById('startDate').readOnly = false;
            document.getElementById('endDate').readOnly = false;
        }

        // Supporting Document Logic (SL > 2 days, ML require it. BL no longer needs it)
        const s = document.getElementById('startDate').value;
        const e = document.getElementById('endDate').value;
        const days = s && e ? countBusinessDays(new Date(s), new Date(e)) : 0;

        if (type.code === 'ML' || (type.code === 'SL' && days > 2)) {
            document.getElementById('docRequired').style.display = 'inline';
            document.getElementById('attachmentInput').required = true;
            document.getElementById('docHint').textContent = '(Required for this leave type)';
        } else {
            document.getElementById('docRequired').style.display = 'none';
            document.getElementById('attachmentInput').required = false;
            document.getElementById('docHint').textContent = '(Optional)';
        }
    } else {
        document.getElementById('bereavementSection').style.display = 'none';
        document.getElementById('docRequired').style.display = 'none';
        document.getElementById('attachmentInput').required = false;
    }
}

function updateBlHint() {
    const rel = document.getElementById('blRelation').value;
    if (!rel) {
        document.getElementById('blHint').style.display = 'none';
        return;
    }

    let max = 3;
    const catA = ["Parent", "Spouse", "Child"];
    const catC = ["Brother-in-law", "Sister-in-law", "Spouse Grand Parent"];

    if (catA.includes(rel)) max = 5;
    else if (catC.includes(rel)) max = 1;

    document.getElementById('blRelationText').textContent = rel;
    document.getElementById('blMaxDays').textContent = max;
    document.getElementById('blHint').style.display = 'block';

    // Highlight if current duration exceeds max
    const s = document.getElementById('startDate').value;
    const e = document.getElementById('endDate').value;
    if (s && e) {
        const days = countBusinessDays(new Date(s), new Date(e));
        if (days > max) {
            document.getElementById('blHint').className = "alert alert-danger py-1 px-2 mt-2 small";
        } else {
            document.getElementById('blHint').className = "alert alert-warning py-1 px-2 mt-2 small";
        }
    }
}

document.getElementById('blRelation').addEventListener('change', updateBlHint);

document.getElementById('LeaveTypeId').addEventListener('change', updateUiForLeaveType);
document.getElementById('startDate').addEventListener('change', function() { updateDays(); updateUiForLeaveType(); });
document.getElementById('endDate').addEventListener('change', function(){
    const s = document.getElementById('startDate').value;
    if (s && this.value < s) this.value = s;
    updateDays();
    updateUiForLeaveType();
});

document.getElementById('floatingHolidaySelect').addEventListener('change', function() {
    const date = this.value;
    if (date) {
        document.getElementById('startDate').value = date;
        document.getElementById('endDate').value = date;
        updateDays();
        updateUiForLeaveType();
    }
});

// Initial call
updateUiForLeaveType();
updateDays();
</script>

<style>
    .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }
</style>
}
