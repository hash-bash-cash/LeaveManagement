@model LMS.Models.EmployeeDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "_EmployeeLayout";
}

<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="border-left-color:#4070f4">
            <p>Pending Requests</p>
            <h2>@Model.PendingRequests</h2>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card" style="border-left-color:#28a745">
            <p>Approved This Year</p>
            <h2>@Model.ApprovedThisYear</h2>
        </div>
    </div>
    @foreach (var b in Model.LeaveBalances.Take(2))
    {
        <div class="col-sm-6 col-xl-3">
            <div class="stat-card" style="border-left-color:#fd7e14">
                <p>@b.LeaveTypeName Remaining</p>
                <h2>@b.Remaining <small style="font-size:14px;color:#aaa">/ @b.Allocated</small></h2>
            </div>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="content-card">
            <h5 class="fw-bold mb-3">Recent Leave Requests</h5>
            @if (!Model.RecentLeaves.Any())
            {
                <div class="text-center text-muted py-4">
                    <i class="fa-solid fa-inbox fa-2x mb-2"></i>
                    <p>No leave requests yet. <a asp-action="Apply">Apply for your first leave →</a></p>
                </div>
            }
            else
            {
                <table class="table table-hover">
                    <thead class="table-light"><tr><th>Type</th><th>From</th><th>To</th><th>Status</th></tr></thead>
                    <tbody>
                    @foreach (var l in Model.RecentLeaves)
                    {
                        <tr>
                            <td>@l.LeaveType?.Name</td>
                            <td>@l.StartDate.ToString("dd MMM yyyy")</td>
                            <td>@l.EndDate.ToString("dd MMM yyyy")</td>
                            <td>
                                @if (l.Cancelled)
                                {
                                    <span class="badge badge-cancelled">Cancelled</span>
                                }
                                else if (l.Approved == null)
                                {
                                    <span class="badge badge-pending">Pending</span>
                                }
                                else if (l.Approved == true)
                                {
                                    <span class="badge badge-approved">Approved</span>
                                }
                                else
                                {
                                    <span class="badge badge-rejected">Rejected</span>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    </div>
    <div class="col-lg-4">
        <div class="content-card">
            <h5 class="fw-bold mb-3">Leave Balance Summary</h5>
            @foreach (var b in Model.LeaveBalances)
            {
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="fw-semibold small">@b.LeaveTypeName</span>
                        <span class="small text-muted">@b.Remaining / @b.Allocated days</span>
                    </div>
                    <div class="progress" style="height:8px">
                        <div class="progress-bar" style="width:@(b.Allocated > 0 ? (b.Used * 100 / b.Allocated) : 0)%; background:var(--accent)"></div>
                    </div>
                </div>
            }
            @if (!Model.LeaveBalances.Any())
            {
                <p class="text-muted small">No leave allocations found. Contact your HR Admin.</p>
            }
        </div>
    </div>
</div>
