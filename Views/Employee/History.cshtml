@model IEnumerable<LMS.Models.LeaveRequest>
@{
    ViewData["Title"] = "Leave History";
    Layout = "_EmployeeLayout";
}

<div class="content-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold mb-0">All Leave Requests</h5>
        <a asp-action="Apply" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-plus me-1"></i> New Request
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="fa-solid fa-folder-open fa-3x mb-3"></i>
            <p>No leave requests found.</p>
            <a asp-action="Apply" class="btn btn-primary">Apply for Leave</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Leave Type</th>
                    <th>From</th>
                    <th>To</th>
                    <th>Days</th>
                    <th>Applied On</th>
                    <th>Remarks</th>
                    <th>Attachment</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var l in Model)
            {
                int days = (int)(l.EndDate - l.StartDate).TotalDays + 1;
                <tr>
                    <td class="text-muted small">#@l.Id</td>
                    <td><span class="fw-semibold">@l.LeaveType?.Name</span></td>
                    <td>@l.StartDate.ToString("dd MMM yyyy")</td>
                    <td>@l.EndDate.ToString("dd MMM yyyy")</td>
                    <td>@days</td>
                    <td>@l.DateRequested.ToLocalTime().ToString("dd MMM yyyy")</td>
                    <td><small class="text-muted">@(string.IsNullOrEmpty(l.RequestComments) ? "—" : l.RequestComments)</small></td>
                    <td>
                        @if (!string.IsNullOrEmpty(l.AttachmentPath))
                        {
                            <a href="@l.AttachmentPath" target="_blank" class="btn btn-link btn-sm p-0 m-0">
                                <i class="fa-solid fa-paperclip me-1"></i> View
                            </a>
                        }
                        else { <span class="text-muted small">—</span> }
                    </td>
                    <td>
                        @if (l.Cancelled)
                        {
                            <span class="badge badge-cancelled px-3 py-2">Cancelled</span>
                        }
                        else if (l.Approved == null)
                        {
                            <span class="badge badge-pending px-3 py-2">⏳ Pending</span>
                        }
                        else if (l.Approved == true)
                        {
                            <span class="badge badge-approved px-3 py-2">✅ Approved</span>
                        }
                        else
                        {
                            <span class="badge badge-rejected px-3 py-2">❌ Rejected</span>
                        }
                    </td>
                    <td>
                        @if (!l.Cancelled && l.Approved != false)
                        {
                            <form asp-action="Cancel" asp-route-id="@l.Id" method="post"
                                  onsubmit="return confirm('Are you sure you want to cancel this leave request?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">Cancel</button>
                            </form>
                        }
                        else { <span class="text-muted">—</span> }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }
</div>
