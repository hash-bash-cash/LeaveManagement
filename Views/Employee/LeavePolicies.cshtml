@model IEnumerable<LMS.Models.LeaveType>
@{
    ViewData["Title"] = "Leave Policies & Rules";
    Layout = User.IsInRole("Admin") ? "_AdminLayout" : (User.IsInRole("Manager") ? "_ManagerLayout" : "_EmployeeLayout");
}

<div class="content-card">
    <div class="d-flex align-items-center mb-4">
        <i class="fa-solid fa-book-open text-primary fs-3 me-3"></i>
        <div>
            <h5 class="fw-bold mb-0">Leave Policies & Guidelines</h5>
            <span class="text-muted small">Understanding your leave entitlements and constraints</span>
        </div>
    </div>

    <div class="alert alert-info mb-4">
        <i class="fa-solid fa-circle-info me-2"></i><strong>General Note:</strong> 
        All leaves requires pre-approval from your manager unless specified otherwise (like emergencies).
        Weekends (Saturday & Sunday) are generally observed as weekly offs and are excluded from leave duration calculations.
    </div>

    <div class="row g-4">
        @foreach (var type in Model)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 shadow-sm border-0" style="border-radius: 12px; transition: transform 0.2s;">
                    <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="fw-bold text-dark mb-1">@type.Name</h6>
                            <span class="badge bg-light text-primary border me-1">@type.Code</span>
                        </div>
                        <div class="text-end">
                            @if(type.IsPaid) { <span class="badge bg-success-subtle text-success border border-success-subtle mb-1">Paid</span> }
                            else { <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle mb-1">Unpaid</span> }
                            <br>
                            @if(type.RequiresApproval) { <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle small px-2 py-1">Manager Approval</span> }
                            else { <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle small px-2 py-1">Auto-Approved</span> }
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="small mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted"><i class="fa-solid fa-calendar-check me-2 opacity-50"></i>Allocation</span>
                                <span class="fw-semibold">@(type.DefaultDays > 0 ? $"{type.DefaultDays} days / year" : "N/A")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted"><i class="fa-solid fa-sync me-2 opacity-50"></i>Carry Forward</span>
                                <span class="fw-semibold @(type.CarryForward ? "text-success" : "text-danger")">@(type.CarryForward ? "Yes" : "No")</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted"><i class="fa-solid fa-layer-group me-2 opacity-50"></i>Max Consecutive</span>
                                <span class="fw-semibold">@(type.MaxConsecutiveDays > 0 ? $"{type.MaxConsecutiveDays} days" : "Unlimited")</span>
                            </div>
                        </div>

                        <div class="p-2 rounded bg-light border-start border-4 border-primary">
                            <p class="mb-1 fw-bold small text-primary">Guidelines & Rules:</p>
                            @if (type.Code == "PL")
                            {
                                <ul class="small mb-0 ps-3">
                                    <li>Min 15 days advance notice.</li>
                                    <li>Credits earned (1.75/mo) after probation.</li>
                                    <li>Priority over other paid leaves.</li>
                                </ul>
                            }
                            else if (type.Code == "ML")
                            {
                                <ul class="small mb-0 ps-3">
                                    <li>Min 80 days service. (Female only)</li>
                                    <li>26 weeks consecutive.</li>
                                    <li>Medical Cert mandatory.</li>
                                </ul>
                            }
                            else if (type.Code == "BL")
                            {
                                <ul class="small mb-0 ps-3">
                                    <li>Max 5 days for immediate family.</li>
                                    <li>Relationship verification required.</li>
                                </ul>
                            }
                            else if (type.Code == "SL")
                            {
                                <ul class="small mb-0 ps-3">
                                    <li>For medical emergencies.</li>
                                    <li>3+ days require Doctor's note.</li>
                                </ul>
                            }
                            else if (type.Code == "CL")
                            {
                                <ul class="small mb-0 ps-3">
                                    <li>Unexpected personal needs.</li>
                                    <li>Subject to balance & approval.</li>
                                </ul>
                            }
                            else if (type.Code == "CO")
                            {
                                <ul class="small mb-0 ps-3">
                                    <li>Expires within 1 month.</li>
                                    <li>Credited by manager only.</li>
                                </ul>
                            }
                            else
                            {
                                <ul class="small mb-0 ps-3 text-muted">
                                    <li>Standard leave policies apply.</li>
                                    <li>Please consult HR handbook.</li>
                                </ul>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
