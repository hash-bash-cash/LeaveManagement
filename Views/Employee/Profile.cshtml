@model LMS.Models.ApplicationUser
@{
    ViewData["Title"] = "My Profile";
    Layout = "_EmployeeLayout";
    var initials = $"{Model.FirstName?.Substring(0,1)}{Model.LastName?.Substring(0,1)}".ToUpper();
}

<div class="row g-4">
    <div class="col-lg-4">
        <div class="content-card text-center">
            <div style="width:90px;height:90px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:32px;font-weight:700;color:white">
                @initials
            </div>
            <h5 class="fw-bold">@Model.FirstName @Model.LastName</h5>
            <p class="text-muted mb-1">@Model.Email</p>
            <span class="badge" style="background:var(--accent)">@Model.Shift Shift</span>

            <hr class="my-3">
            <div class="text-start">
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted small">Status</span>
                    <span class="badge badge-approved">@Model.Status</span>
                </div>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted small">Date Joined</span>
                    <span class="small fw-semibold">@Model.DateJoined.ToLocalTime().ToString("dd MMM yyyy")</span>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span class="text-muted small">Employee Code</span>
                    <span class="small fw-semibold">@(string.IsNullOrEmpty(Model.EmployeeCode) ? "N/A" : Model.EmployeeCode)</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="content-card mb-4">
            <h6 class="fw-bold mb-3">Contact Information</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="text-muted small">Email Address</label>
                    <p class="fw-semibold mb-0">@Model.Email</p>
                </div>
                <div class="col-md-6">
                    <label class="text-muted small">Phone</label>
                    <p class="fw-semibold mb-0">@(string.IsNullOrEmpty(Model.Phone) ? "N/A" : Model.Phone)</p>
                </div>
            </div>
        </div>

        <div class="content-card">
            <h6 class="fw-bold mb-3">Organizational Details</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="text-muted small">Department</label>
                    <p class="fw-semibold mb-0">@(Model.Department?.Name ?? "Not Assigned")</p>
                </div>
                <div class="col-md-6">
                    <label class="text-muted small">Team</label>
                    <p class="fw-semibold mb-0">@(Model.Team?.Name ?? "Not Assigned")</p>
                </div>
                <div class="col-md-6">
                    <label class="text-muted small">Shift</label>
                    <p class="fw-semibold mb-0">@(string.IsNullOrEmpty(Model.Shift) ? "N/A" : Model.Shift)</p>
                </div>
            </div>
        </div>
    </div>
</div>
