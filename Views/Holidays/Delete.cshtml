@model LMS.Models.Holiday

@{
    ViewData["Title"] = "Delete Holiday";
    Layout = "_AdminLayout";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-danger text-white py-4 text-center">
                    <h3 class="fw-bold mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Delete Holiday</h3>
                </div>
                <div class="card-body p-5 text-center">
                    <div class="mb-4">
                        <div class="display-6 fw-bold text-dark mb-1">@Model.Name</div>
                        <div class="text-muted"><i class="bi bi-calendar3 me-1"></i> @Model.Date.ToString("dd MMM yyyy")</div>
                    </div>

                    <p class="text-secondary mb-5">Are you sure you want to delete this holiday? This action cannot be undone and will affect all assigned employees.</p>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Manage" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                            <button type="submit" class="btn btn-danger rounded-pill px-4 shadow-sm">Confirm Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
