@{
    ViewData["Title"] = "Import Holidays";
    Layout = "_AdminLayout";
    var departments = ViewData["Departments"] as IEnumerable<LMS.Models.Department>;
}

<div class="container py-4">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden max-w-md mx-auto" style="max-width: 600px;">
        <div class="card-header bg-white border-bottom py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-file-earmark-excel me-2 text-success"></i>Import Holiday Calendar</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Import" enctype="multipart/form-data" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Select Excel File (.xlsx)</label>
                    <input type="file" name="excelFile" class="form-control" accept=".xlsx" required />
                    <div class="form-text">
                        Download the <a href="javascript:void(0)" onclick="downloadTemplate()"><i class="bi bi-download"></i> Sample Template</a>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold mb-2">Apply to Departments</label>
                    <div class="text-muted small mb-2">Select the departments that will follow this calendar. Leave unchecked to apply to all employees (Global).</div>
                    
                    <div class="row g-2">
                        @if (departments != null)
                        {
                            foreach (var dept in departments)
                            {
                                <div class="col-6">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" name="departmentIds" value="@dept.Id" id="dept_@dept.Id">
                                        <label class="form-check-label" for="dept_@dept.Id">
                                            @dept.Name
                                        </label>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                    <a asp-action="Manage" class="btn btn-light rounded-pill px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">
                        <i class="bi bi-upload me-1"></i> Import Holidays
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function downloadTemplate() {
        // Create an empty basic CSV/Excel structure programmatically via data URI for the sample
        const header = "Name,Date(YYYY-MM-DD),IsRecurringYearly(Yes/No),IsFloating(Yes/No)\nNew Year,2026-01-01,Yes,No\nChristmas,2026-12-25,Yes,No";
        const blob = new Blob([header], { type: 'text/csv' });
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.setAttribute('hidden', '');
        a.setAttribute('href', url);
        a.setAttribute('download', 'HolidayTemplate.csv');
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
    }
</script>
