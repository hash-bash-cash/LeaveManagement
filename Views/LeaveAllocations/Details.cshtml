@model LMS.Controllers.ViewAllocationsViewModel
@{
    ViewData["Title"] = $"Leave Allocations - {Model.Employee.FirstName} {Model.Employee.LastName}";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a asp-controller="Users" asp-action="Index">Users</a></li>
                    <li class="breadcrumb-item active">@Model.Employee.FirstName</li>
                </ol>
            </nav>
            <h2 class="fw-bold">@ViewData["Title"]</h2>
            <p class="text-muted mb-0">@Model.Employee.Email · @Model.Employee.EmployeeCode</p>
        </div>
        <a asp-controller="Users" asp-action="Index" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left me-1"></i> Back to Users
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">@TempData["Success"]</div>
    }

    <div class="card border-0 shadow-sm overflow-hidden">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="fw-bold mb-0">Current Allocations (@DateTime.Now.Year)</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Leave Type</th>
                        <th class="text-center">Days Allocated</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Allocations.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-folder-open fa-2x mb-2 d-block"></i>
                                No allocations found for this year.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var allocation in Model.Allocations)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold">@allocation.LeaveType?.Name</div>
                                    <small class="text-muted">Modified: @(allocation.DateModified == DateTime.MinValue ? allocation.DateCreated.ToString("dd MMM yyyy") : allocation.DateModified.ToString("dd MMM yyyy"))</small>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-primary px-3 py-2 fs-6">@((int)Math.Floor(allocation.NumberOfDays))</span>
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editModal-@allocation.Id">
                                        <i class="fa-solid fa-edit me-1"></i> Edit
                                    </button>

                                    <!-- Edit Modal -->
                                    <div class="modal fade" id="editModal-@allocation.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content border-0 shadow">
                                                <form asp-action="EditAllocation" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@allocation.Id" />
                                                    <div class="modal-header border-0 pb-0">
                                                        <h5 class="modal-title fw-bold">Edit Allocation</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body text-start mt-2">
                                                        <p class="text-muted small mb-3">Updating <strong>@allocation.LeaveType?.Name</strong> for @Model.Employee.FirstName.</p>
                                                        <label class="form-label fw-semibold">Number of Days</label>
                                                        <input type="number" name="numberOfDays" class="form-control" value="@allocation.NumberOfDays" min="0" step="0.5" required />
                                                    </div>
                                                    <div class="modal-footer border-0">
                                                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-primary fw-bold px-4">Save Changes</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
