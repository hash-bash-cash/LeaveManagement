@model LMS.Models.ApplyLeaveViewModel
@{
    ViewData["Title"] = "Apply for Leave";
    Layout = "_ManagerLayout";
}

<div class="row justify-content-center">
<div class="col-lg-7">
<div class="content-card">
    <div class="alert alert-info mb-4">
        <i class="fa-solid fa-info-circle me-2"></i>
        As a Manager, your leave request will go to the <strong>Admin</strong> for approval.
    </div>

    <h5 class="fw-bold mb-4"><i class="fa-solid fa-paper-plane me-2"></i>New Leave Application</h5>

    <form asp-action="ApplyLeave" method="post" id="mLeaveForm">
        @if (ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert alert-danger">
                <ul class="mb-0">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <li>@err.ErrorMessage</li>
                }
                </ul>
            </div>
        }

        <div class="row g-3">
            <div class="col-12">
                <label class="form-label fw-semibold">Leave Type *</label>
                <select asp-for="LeaveTypeId" class="form-select" required>
                    <option value="">— Select Leave Type —</option>
                    @foreach (var t in Model.LeaveTypes)
                    {
                        <option value="@t.Id">@t.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">Start Date *</label>
                <input asp-for="StartDate" type="date" class="form-control" id="mStartDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
            </div>
            <div class="col-md-6">
                <label class="form-label fw-semibold">End Date *</label>
                <input asp-for="EndDate" type="date" class="form-control" id="mEndDate" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
            </div>
            <div class="col-12">
                <div class="alert alert-info py-2 px-3 mb-0" id="mDaysSummary" style="display:none">
                    Working days requested: <strong id="mTotalDays">0</strong>
                </div>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold">Reason *</label>
                <textarea asp-for="Reason" class="form-control" rows="4" placeholder="Reason for leave..." required></textarea>
            </div>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-success px-4"><i class="fa-solid fa-paper-plane me-1"></i> Submit Request</button>
            <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>
</div>
</div>

@section Scripts {
<script>
function countDays(s, e) {
    let c = 0, d = new Date(s);
    while (d <= e) { if (d.getDay()!==0&&d.getDay()!==6) c++; d.setDate(d.getDate()+1); }
    return c;
}
function update() {
    const s=document.getElementById('mStartDate').value, e=document.getElementById('mEndDate').value;
    if(s&&e&&s<=e){document.getElementById('mTotalDays').textContent=countDays(new Date(s),new Date(e));document.getElementById('mDaysSummary').style.display='block';}
    else document.getElementById('mDaysSummary').style.display='none';
}
document.getElementById('mStartDate').onchange=update;
document.getElementById('mEndDate').onchange=update;
</script>
}
