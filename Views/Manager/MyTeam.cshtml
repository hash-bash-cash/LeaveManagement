@model IEnumerable<LMS.Models.TeamMemberBalanceViewModel>
@{
    ViewData["Title"] = "My Team Portal";
    Layout = "_ManagerLayout";
}

<div class="content-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h5 class="fw-bold mb-0 text-primary"><i class="fa-solid fa-users-gear me-2"></i> Team Portal</h5>
            <p class="text-muted small mb-0">Manage your team's leaves and view their balances in one place.</p>
        </div>
        <a asp-action="CreditCO" class="btn btn-outline-primary btn-sm rounded-pill px-3 shadow-sm">
            <i class="fa-solid fa-star me-1"></i> Credit CO
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 text-muted bg-light rounded-4 border border-dashed">
            <i class="fa-solid fa-users-slash fa-3x mb-3 opacity-25"></i>
            <h5 class="fw-bold">No Team Members Found</h5>
            <p>Your team directory is currently empty. Please contact HR for assignments.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var m in Model)
            {
                var initials = $"{m.EmployeeName.Split(' ')[0][0]}{(m.EmployeeName.Split(' ').Length > 1 ? m.EmployeeName.Split(' ')[1][0] : "")}".ToUpper();
                <div class="col-md-6 col-xl-4">
                    <div class="card h-100 border-0 shadow-sm employee-card" data-bs-toggle="modal" data-bs-target="#modal_@m.EmployeeId" style="cursor: pointer; transition: all 0.3s cubic-bezier(.25,.8,.25,1); border-radius: 16px; overflow: hidden;">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center gap-3">
                                <div class="avatar-circle">@initials</div>
                                <div class="overflow-hidden">
                                    <h6 class="fw-bold text-truncate mb-0">@m.EmployeeName</h6>
                                    <div class="text-muted small text-truncate">@m.Email</div>
                                </div>
                            </div>
                            
                            <hr class="my-3 opacity-10">
                            
                            <div class="row g-2 text-center">
                                @foreach(var b in m.Balances.Where(x => x.LeaveTypeName.Contains("Paid") || x.LeaveTypeName.Contains("Casual")).Take(2))
                                {
                                    <div class="col-6">
                                        <div class="p-2 bg-light rounded-3">
                                            <div class="text-muted" style="font-size: 10px; font-weight: 700; text-uppercase; letter-spacing: 0.5px;">@b.LeaveTypeName</div>
                                            <div class="fw-bold text-primary">@b.Remaining <small class="text-muted fw-normal" style="font-size: 11px">/@b.Allocated</small></div>
                                        </div>
                                    </div>
                                }
                            </div>
                            
                            <div class="mt-3 text-end">
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-1 small">
                                    <i class="fa-solid fa-eye me-1"></i> View Detailed History
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Modal for Detailed Info -->
                <div class="modal fade" id="modal_@m.EmployeeId" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
                            <div class="modal-header border-0 pb-0 pt-4 px-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-circle-sm">@initials</div>
                                    <div>
                                        <h5 class="modal-title fw-bold">@m.EmployeeName</h5>
                                        <div class="text-muted small">@m.Email • <span class="badge bg-light text-dark">@m.Shift Shift</span></div>
                                    </div>
                                </div>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body p-4 mt-2">
                                <!-- Balance Section -->
                                <h6 class="fw-bold mb-3 d-flex align-items-center"><i class="fa-solid fa-wallet me-2 text-primary"></i> Leave Balances (@DateTime.Now.Year)</h6>
                                <div class="row g-3 mb-4">
                                    @foreach (var devB in m.Balances)
                                    {
                                        bool isGeneral = devB.LeaveTypeName.Contains("Paid", StringComparison.OrdinalIgnoreCase) || 
                                                         devB.LeaveTypeName.Contains("Casual", StringComparison.OrdinalIgnoreCase) || 
                                                         devB.LeaveTypeName.Contains("Sick", StringComparison.OrdinalIgnoreCase);
                                                         
                                        if (!isGeneral && devB.Used == 0) continue;
                                        
                                        string leaveColor = isGeneral ? "var(--personal-accent)" : "#f59e0b"; // Highlight special leaves
                                        string bgClass = isGeneral ? "bg-white" : "bg-warning-subtle border-warning-subtle";

                                        <div class="col-md-4">
                                            <div class="p-3 border rounded-4 @bgClass shadow-sm h-100" style="transition: transform 0.2s;">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <div class="small fw-bold text-muted text-uppercase" style="font-size: 11px;">@devB.LeaveTypeName</div>
                                                    @if(!isGeneral)
                                                    {
                                                        <i class="fa-solid fa-star" style="color: @leaveColor; font-size: 12px;"></i>
                                                    }
                                                </div>
                                                <div class="h3 mb-2 fw-bold" style="color: @leaveColor;">@devB.Remaining <span style="font-size: 14px; font-weight: normal; color: #888;">left</span></div>
                                                <div class="progress" style="height: 6px; border-radius: 10px; background-color: rgba(0,0,0,0.05);">
                                                    <div class="progress-bar" role="progressbar" style="width: @(devB.Allocated > 0 ? (devB.Used * 100 / devB.Allocated) : (devB.Used > 0 ? 100 : 0))%; background: @leaveColor;"></div>
                                                </div>
                                                <div class="text-muted mt-2 d-flex justify-content-between" style="font-size: 11px;">
                                                    <span>Taken: <strong>@devB.Used</strong></span>
                                                    <span>Total: <strong>@devB.Allocated</strong></span>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>

                                <!-- History Section -->
                                <h6 class="fw-bold mb-3 d-flex align-items-center"><i class="fa-solid fa-history me-2 text-primary"></i> Recent Leave History</h6>
                                <div class="table-responsive bg-light rounded-4 border overflow-hidden">
                                    <table class="table table-sm table-hover mb-0 align-middle">
                                        <thead class="bg-white border-bottom">
                                            <tr>
                                                <th class="ps-3 py-3 border-0">Leave Type</th>
                                                <th class="py-3 border-0">Dates</th>
                                                <th class="py-3 border-0">Status</th>
                                                <th class="text-end pe-3 py-3 border-0">Applied On</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @if (!m.History.Any())
                                            {
                                                <tr><td colspan="4" class="text-center py-4 text-muted">No history found for this employee.</td></tr>
                                            }
                                            @foreach (var h in m.History.Take(10))
                                            {
                                                <tr>
                                                    <td class="ps-3 py-2 fw-semibold">@h.LeaveType?.Name</td>
                                                    <td class="py-2 small">@h.StartDate.ToString("dd MMM") - @h.EndDate.ToString("dd MMM")</td>
                                                    <td class="py-2">
                                                        @if (h.Approved == true) { <span class="badge bg-success-subtle text-success small rounded-pill">Approved</span> }
                                                        else if (h.Approved == false) { <span class="badge bg-danger-subtle text-danger small rounded-pill">Rejected</span> }
                                                        else { <span class="badge bg-warning-subtle text-warning-emphasis small rounded-pill">Pending</span> }
                                                    </td>
                                                    <td class="text-end pe-3 py-2 text-muted" style="font-size: 11px;">@h.DateRequested.ToString("dd MMM yyyy")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <div class="modal-footer border-0 p-4 pt-0">
                                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Close</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .avatar-circle {
        width: 52px; height: 52px; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        color: white; font-weight: 700; font-size: 18px; flex-shrink: 0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }
    .avatar-circle-sm {
        width: 44px; height: 44px; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        color: white; font-weight: 700; font-size: 14px; flex-shrink: 0;
    }
    .employee-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04) !important;
        border: 1px solid rgba(79, 70, 229, 0.2) !important;
    }
    .modal-lg { max-width: 850px; }
    .progress-bar { transition: width 0.6s ease; }
</style>
