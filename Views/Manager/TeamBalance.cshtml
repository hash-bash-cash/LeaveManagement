@model IEnumerable<LMS.Models.TeamMemberBalanceViewModel>
@{
    ViewData["Title"] = "Team Leave Balance";
    Layout = "_ManagerLayout";
}

@if (!Model.Any())
{
    <div class="content-card text-center py-5">
        <i class="fa-solid fa-scale-balanced fa-3x text-muted mb-3"></i>
        <h5>No Team Members</h5><p class="text-muted">No employees assigned to your team yet.</p>
    </div>
}
else
{
    @foreach (var member in Model)
    {
        <div class="content-card mb-4">
            <div class="d-flex align-items-center gap-3 mb-3 pb-2 border-bottom">
                <div style="width:38px;height:38px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-weight:700">
                    @member.EmployeeName.Substring(0,1)
                </div>
                <div>
                    <div class="fw-bold">@member.EmployeeName</div>
                    <small class="text-muted">@member.Email · @member.Shift Shift</small>
                </div>
            </div>
            @if (!member.Balances.Any())
            {
                <p class="text-muted small">No leave allocations found for this employee.</p>
            }
            else
            {
                <div class="row g-3">
                @foreach (var b in member.Balances)
                {
                    bool isGeneral = b.LeaveTypeName.Contains("Paid", StringComparison.OrdinalIgnoreCase) || 
                                     b.LeaveTypeName.Contains("Casual", StringComparison.OrdinalIgnoreCase) || 
                                     b.LeaveTypeName.Contains("Sick", StringComparison.OrdinalIgnoreCase);

                    if (!isGeneral && b.Used == 0) continue;

                    var pct = b.Allocated > 0 ? (b.Used * 100 / b.Allocated) : (b.Used > 0 ? 100 : 0);
                    var barColor = pct >= 80 ? "#dc3545" : pct >= 50 ? "#fd7e14" : (isGeneral ? "var(--accent)" : "#f59e0b");
                    string bgClass = isGeneral ? "bg-white" : "bg-warning-subtle border-warning-subtle";

                    <div class="col-md-4">
                        <div class="p-3 border rounded @bgClass shadow-sm" style="transition: transform 0.2s;">
                            <div class="d-flex justify-content-between mb-1 align-items-center">
                                <span class="small fw-bold text-uppercase" style="font-size: 11px;">@b.LeaveTypeName</span>
                                @if(!isGeneral) { <i class="fa-solid fa-star" style="color: @barColor; font-size: 12px;"></i> }
                            </div>
                            <div class="progress" style="height:8px;margin-bottom:6px">
                                <div class="progress-bar" style="width:@pct%;background:@barColor"></div>
                            </div>
                            <div class="d-flex justify-content-between mt-2">
                                <span class="small text-muted">Used: <strong>@b.Used</strong> / @b.Allocated</span>
                                <span class="small fw-bold" style="color:@barColor">@b.Remaining left</span>
                            </div>
                        </div>
                    </div>
                }
                </div>
            }
        </div>
    }
}
