@model IEnumerable<LMS.Models.LeaveRequest>
@{
    ViewData["Title"] = "Team Leave Calendar";
    Layout = "_ManagerLayout";
    var conflicts = ViewBag.Conflicts as List<DateTime> ?? new List<DateTime>();
}

@if (conflicts.Any())
{
    <div class="alert alert-warning mb-4">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>
        <strong>Conflict Alert!</strong> Multiple team members are on leave on the same day(s):
        @foreach (var c in conflicts)
        {
            <span class="badge" style="background:#fd7e14;margin-left:6px">@c.ToString("dd MMM")</span>
        }
    </div>
}

<div class="content-card">
    <h5 class="fw-bold mb-4"><i class="fa-solid fa-calendar-check me-2 text-primary"></i>Approved Leaves — Next 60 Days</h5>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-4">
            <i class="fa-regular fa-calendar-check fa-3x mb-3"></i>
            <p>No approved leaves scheduled in the next 60 days.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light"><tr><th>Employee</th><th>Leave Type</th><th>From</th><th>To</th><th>Days</th><th>Conflict?</th></tr></thead>
            <tbody>
            @foreach (var r in Model)
            {
                int days = (int)(r.EndDate - r.StartDate).TotalDays + 1;
                bool hasConflict = conflicts.Any(c => c >= r.StartDate.Date && c <= r.EndDate.Date);
                <tr class="@(hasConflict ? "table-warning" : "")">
                    <td>
                        <div class="fw-semibold">@r.RequestingEmployee?.FirstName @r.RequestingEmployee?.LastName</div>
                    </td>
                    <td><span class="badge badge-pending">@r.LeaveType?.Name</span></td>
                    <td>@r.StartDate.ToString("dd MMM yyyy")</td>
                    <td>@r.EndDate.ToString("dd MMM yyyy")</td>
                    <td><strong>@days</strong></td>
                    <td>
                        @if (hasConflict)
                        {
                            <span class="badge" style="background:#dc3545"><i class="fa-solid fa-triangle-exclamation me-1"></i> Conflict</span>
                        }
                        else { <span class="text-muted">—</span> }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }
</div>
