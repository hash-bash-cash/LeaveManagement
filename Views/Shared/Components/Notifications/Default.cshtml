@model IEnumerable<LMS.Models.Notification>
@{
    var unreadCount = Model.Count(n => !n.IsRead);
}

<li class="nav-item dropdown me-3">
    <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="notificationsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
        <div style="position: relative;">
            <i class="bi bi-bell fs-5 text-dark"></i>
            @if (unreadCount > 0)
            {
                <span class="position-absolute translate-middle badge rounded-pill bg-danger" style="top: -2px; left: 18px; font-size: 0.6rem;">
                    @unreadCount
                </span>
            }
        </div>
    </a>
    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="notificationsDropdown" style="width: 320px; max-height: 480px; overflow-y: auto;">
        <li class="px-3 py-2 border-bottom fw-bold d-flex justify-content-between align-items-center bg-light">
            <span>Notifications</span>
            @if (unreadCount > 0)
            {
                <form asp-controller="Notifications" asp-action="MarkAllAsRead" method="post" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-link text-decoration-none p-0 small">Mark all as read</button>
                </form>
            }
        </li>

        @if (!Model.Any())
        {
            <li class="px-3 py-4 text-center text-muted">
                <i class="bi bi-bell-slash fs-4 mb-2"></i>
                <p class="mb-0 small">No notifications yet.</p>
            </li>
        }
        else
        {
            foreach (var n in Model)
            {
                <li class="border-bottom">
                    <div class="px-3 py-2 @(n.IsRead ? "" : "bg-light")">
                        <div class="d-flex justify-content-between">
                            <strong class="small text-truncate">@n.Title</strong>
                            <small class="text-muted" style="font-size: 0.7rem;">@n.CreatedAt.ToString("MMM dd, HH:mm")</small>
                        </div>
                        <p class="small mb-1 mt-1 text-wrap" style="line-height: 1.2;">@n.Message</p>
                    </div>
                </li>
            }
        }
        <li class="border-top text-center mt-2">
            <a asp-controller="Notifications" asp-action="Index" class="dropdown-item small text-primary fw-bold py-2">View All Notifications</a>
        </li>
    </ul>
</li>
