<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Portal | LMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --admin-dark: #0f172a;
            --admin-sidebar: #1e293b;
            --admin-sidebar-hover: #334155;
            --admin-accent: #6366f1;
            --admin-accent-light: #818cf8;
            --admin-text: #e2e8f0;
            --admin-text-muted: #94a3b8;
            --admin-border: #334155;
        }
        body { background: #f1f5f9; font-family: 'Segoe UI', sans-serif; }

        /* Sidebar */
        .admin-sidebar {
            position: fixed; top: 0; left: 0;
            width: 260px; height: 100vh;
            background: var(--admin-sidebar);
            display: flex; flex-direction: column;
            z-index: 1000; overflow-y: auto;
            box-shadow: 4px 0 15px rgba(0,0,0,0.25);
        }
        .admin-logo {
            padding: 24px 20px 20px;
            border-bottom: 1px solid var(--admin-border);
        }
        .admin-logo .brand {
            font-size: 1.4rem; font-weight: 800;
            color: #fff; letter-spacing: 0.5px;
        }
        .admin-logo .brand span { color: var(--admin-accent-light); }
        .admin-logo .role-badge {
            font-size: 0.7rem; background: var(--admin-accent);
            color: #fff; padding: 2px 10px; border-radius: 20px;
            display: inline-block; margin-top: 6px;
        }
        .sidebar-nav { flex: 1; padding: 12px 0; }
        .nav-section-label {
            padding: 16px 20px 6px;
            font-size: 0.65rem; font-weight: 700;
            color: var(--admin-text-muted);
            text-transform: uppercase; letter-spacing: 1.5px;
        }
        .sidebar-link {
            display: flex; align-items: center; gap: 12px;
            padding: 10px 20px; color: var(--admin-text-muted);
            text-decoration: none; font-size: 0.88rem; font-weight: 500;
            border-left: 3px solid transparent;
            transition: all 0.2s ease;
        }
        .sidebar-link:hover, .sidebar-link.active {
            background: var(--admin-sidebar-hover);
            color: #fff; border-left-color: var(--admin-accent);
        }
        .sidebar-link i { font-size: 1.05rem; width: 20px; text-align: center; }
        .sidebar-submenu { padding-left: 32px; }
        .sidebar-submenu .sidebar-link { font-size: 0.82rem; padding: 7px 14px; }

        /* Topbar */
        .admin-topbar {
            margin-left: 260px; height: 65px;
            background: #fff; display: flex; align-items: center;
            justify-content: space-between; padding: 0 28px;
            border-bottom: 1px solid #e2e8f0;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            position: sticky; top: 0; z-index: 999;
        }
        .topbar-title { font-size: 1.1rem; font-weight: 700; color: #1e293b; }
        .topbar-right { display: flex; align-items: center; gap: 16px; }
        .admin-badge { background: var(--admin-accent); color: #fff; border-radius: 20px; padding: 4px 14px; font-size: 0.78rem; font-weight: 600; }

        /* Main content */
        .admin-content { margin-left: 260px; padding: 32px; min-height: calc(100vh - 65px); }

        /* Cards */
        .stat-card {
            background: #fff; border-radius: 14px; padding: 22px 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06); border: 1px solid #e2e8f0;
            display: flex; align-items: center; gap: 18px;
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .stat-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(0,0,0,0.1); }
        .stat-icon {
            width: 56px; height: 56px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.5rem; flex-shrink: 0;
        }
        .stat-value { font-size: 2rem; font-weight: 800; color: #1e293b; line-height: 1; }
        .stat-label { font-size: 0.82rem; color: #64748b; font-weight: 500; margin-top: 3px; }

        /* Alerts */
        .alert { border-radius: 10px; border: none; }

        /* Tables */
        .admin-table { background: #fff; border-radius: 14px; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
        .admin-table .table { margin-bottom: 0; }
        .admin-table .table thead { background: #f8fafc; }
        .admin-table .table thead th { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #64748b; border-bottom: 2px solid #e2e8f0; padding: 14px 16px; }
        .admin-table .table tbody td { padding: 13px 16px; font-size: 0.9rem; vertical-align: middle; border-color: #f1f5f9; }
        .admin-table .table tbody tr:hover { background: #f8fafc; }

        /* Page header */
        .page-header { margin-bottom: 28px; }
        .page-header h2 { font-size: 1.6rem; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
        .page-header p { color: #64748b; font-size: 0.9rem; margin: 0; }

        /* Badges */
        .badge-pending { background: #fef3c7; color: #92400e; }
        .badge-approved { background: #d1fae5; color: #065f46; }
        .badge-rejected { background: #fee2e2; color: #991b1b; }
        .badge-cancelled { background: #f1f5f9; color: #475569; }

        @@media (max-width: 768px) {
            .admin-sidebar { display: none; }
            .admin-topbar, .admin-content { margin-left: 0; }
        }
    </style>
</head>
<body>

<!-- SIDEBAR -->
<aside class="admin-sidebar">
    <div class="admin-logo">
        <div class="brand">LMS <span>Admin</span></div>
        <div class="role-badge">Administrator</div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section-label">Main</div>
        <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" && ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
           asp-controller="Admin" asp-action="Dashboard">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="nav-section-label">Leave Management</div>
        <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "AllLeaveRequests" ? "active" : "")"
           asp-controller="Admin" asp-action="AllLeaveRequests">
            <i class="bi bi-list-ul"></i> All Leave Requests
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "PendingApprovals" ? "active" : "")"
           asp-controller="Admin" asp-action="PendingApprovals">
            <i class="bi bi-hourglass-split"></i> Pending Approvals
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "ApprovedLeaves" ? "active" : "")"
           asp-controller="Admin" asp-action="ApprovedLeaves">
            <i class="bi bi-check-circle"></i> Approved Leaves
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "RejectedLeaves" ? "active" : "")"
           asp-controller="Admin" asp-action="RejectedLeaves">
            <i class="bi bi-x-circle"></i> Rejected Leaves
        </a>

        <div class="nav-section-label">Organization</div>
        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Departments" ? "active" : "")"
           asp-controller="Departments" asp-action="Index">
            <i class="bi bi-diagram-3"></i> Departments
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Teams" ? "active" : "")"
           asp-controller="Teams" asp-action="Index">
            <i class="bi bi-people"></i> Teams
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "HolidayCalendar" ? "active" : "")"
           asp-controller="Admin" asp-action="HolidayCalendar">
            <i class="bi bi-calendar-event"></i> Holiday Calendar
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "LeaveStructure" ? "active" : "")"
           asp-controller="Admin" asp-action="LeaveStructure">
            <i class="bi bi-journal-text"></i> Leave Structure
        </a>

        <div class="nav-section-label">Users</div>
        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
           asp-controller="Users" asp-action="Index">
            <i class="bi bi-people"></i> User Management
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Pending" ? "active" : "")"
           asp-controller="Users" asp-action="Pending">
            <i class="bi bi-person-check"></i> Pending Registrations
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "LeaveAllocations" ? "active" : "")"
           asp-controller="LeaveAllocations" asp-action="Index">
            <i class="bi bi-pie-chart"></i> Leave Allocations
        </a>
    </nav>

    <div style="padding: 16px 20px; border-top: 1px solid var(--admin-border);">
        <partial name="_LoginPartial" />
    </div>
</aside>

<!-- TOPBAR -->
<div class="admin-topbar">
    <div class="topbar-title">@ViewData["Title"]</div>
    <div class="topbar-right">
        <ul class="navbar-nav me-3 mb-0" style="list-style: none;">@await Component.InvokeAsync("Notifications")</ul>
        <span class="admin-badge"><i class="bi bi-shield-check me-1"></i>Admin</span>
    </div>
</div>

<!-- CONTENT -->
<main class="admin-content">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()
</main>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
