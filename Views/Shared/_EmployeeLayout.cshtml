<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LMS Employee Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --sidebar-bg: #1a2035;
            --sidebar-hover: #2a3555;
            --sidebar-active: #4070f4;
            --sidebar-width: 260px;
            --accent: #4070f4;
        }

        body { background: #f4f6fc; font-family: 'Segoe UI', sans-serif; }

        /* ── Sidebar ── */
        .lms-sidebar {
            width: var(--sidebar-width);
            min-height: 100vh;
            background: var(--sidebar-bg);
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            box-shadow: 4px 0 15px rgba(0,0,0,.2);
        }

        .sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,.08);
        }

        .sidebar-brand h4 { color: #fff; margin: 0; font-weight: 700; letter-spacing: 1px; }
        .sidebar-brand small { color: rgba(255,255,255,.5); font-size: 11px; }

        .sidebar-user {
            padding: 16px 20px;
            border-bottom: 1px solid rgba(255,255,255,.08);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 40px; height: 40px;
            background: var(--accent);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            color: white; font-weight: 700; font-size: 16px;
            flex-shrink: 0;
        }

        .user-info small { color: rgba(255,255,255,.5); font-size: 11px; display: block; }
        .user-info span { color: #fff; font-size: 13px; font-weight: 600; }

        .sidebar-nav { padding: 12px 0; flex: 1; overflow-y: auto; }

        .nav-section-title {
            padding: 12px 20px 4px;
            color: rgba(255,255,255,.35);
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            font-weight: 700;
        }

        .sidebar-nav .nav-link {
            padding: 10px 20px;
            color: rgba(255,255,255,.7);
            display: flex;
            align-items: center;
            gap: 12px;
            border-radius: 0;
            transition: all .2s;
            font-size: 13.5px;
            position: relative;
        }

        .sidebar-nav .nav-link i {
            width: 18px; text-align: center;
            font-size: 14px;
        }

        .sidebar-nav .nav-link:hover {
            background: var(--sidebar-hover);
            color: #fff;
        }

        .sidebar-nav .nav-link.active {
            background: var(--accent);
            color: #fff;
        }

        .sidebar-nav .nav-link.active::before {
            content: '';
            position: absolute;
            left: 0; top: 0; bottom: 0;
            width: 3px;
            background: rgba(255,255,255,.8);
        }

        /* ── Main Content ── */
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }

        .topbar {
            background: #fff;
            padding: 14px 28px;
            border-bottom: 1px solid #e8ecf4;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 2px 8px rgba(0,0,0,.04);
        }

        .topbar-title { font-weight: 600; color: #1a2035; font-size: 17px; }
        .content-area { padding: 28px; }

        /* ── Cards ── */
        .stat-card {
            background: #fff;
            border-radius: 12px;
            padding: 22px;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
            border-left: 4px solid var(--accent);
            transition: transform .2s;
        }
        .stat-card:hover { transform: translateY(-2px); }
        .stat-card h2 { font-weight: 700; color: #1a2035; margin: 0; }
        .stat-card p { margin: 0; color: #888; font-size: 13px; }

        .content-card {
            background: #fff;
            border-radius: 12px;
            padding: 24px;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
        }

        .badge-pending { background: #fff3cd; color: #856404; }
        .badge-approved { background: #d1e7dd; color: #0f5132; }
        .badge-rejected { background: #f8d7da; color: #842029; }
        .badge-cancelled { background: #e9ecef; color: #6c757d; }

        .balance-card {
            background: linear-gradient(135deg, var(--accent), #6e96ff);
            border-radius: 12px;
            padding: 22px;
            color: white;
        }

        .balance-card h2 { font-weight: 700; font-size: 2.2rem; margin: 0; }

        /* ── Form ── */
        .form-card { background: #fff; border-radius: 12px; padding: 28px; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
        .form-control:focus, .form-select:focus { border-color: var(--accent); box-shadow: 0 0 0 .25rem rgba(64,112,244,.15); }
        .btn-primary { background: var(--accent); border: none; }
        .btn-primary:hover { background: #2d5bd4; }
    </style>
</head>
<body>

<div class="lms-sidebar">
    <div class="sidebar-brand">
        <h4><i class="fa-solid fa-calendar-check me-2"></i> LMS</h4>
        <small>Leave Management System</small>
    </div>

    <div class="sidebar-user">
        <div class="user-avatar">@(User.Identity?.Name?.Substring(0,1).ToUpper() ?? "U")</div>
        <div class="user-info">
            <small>Employee</small>
            <span>@User.Identity?.Name</span>
        </div>
    </div>

    <nav class="sidebar-nav">
        <div class="nav-section-title">Main</div>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Dashboard" ? "active" : "")" 
           asp-controller="Employee" asp-action="Dashboard">
            <i class="fa-solid fa-gauge-high"></i> Dashboard
        </a>

        <div class="nav-section-title">My Leaves</div>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Apply" ? "active" : "")" 
           asp-controller="Employee" asp-action="Apply">
            <i class="fa-solid fa-plus-circle"></i> Apply Leave
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "History" ? "active" : "")" 
           asp-controller="Employee" asp-action="History">
            <i class="fa-solid fa-clock-rotate-left"></i> Leave History
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Balance" ? "active" : "")" 
           asp-controller="Employee" asp-action="Balance">
            <i class="fa-solid fa-scale-balanced"></i> Leave Balance
        </a>

        <div class="nav-section-title">Company</div>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Holidays" ? "active" : "")" 
           asp-controller="Employee" asp-action="Holidays">
            <i class="fa-solid fa-calendar-days"></i> Holiday Calendar
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "LeavePolicies" ? "active" : "")" 
           asp-controller="Employee" asp-action="LeavePolicies">
            <i class="fa-solid fa-book-open"></i> Leave Policies
        </a>

        <div class="nav-section-title">Account</div>
        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")" 
           asp-controller="Employee" asp-action="Profile">
            <i class="fa-solid fa-user-circle"></i> My Profile
        </a>
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Logout" 
           onclick="document.forms['logout-form'].submit(); return false;">
            <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
        <form id="logout-form" asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-none">
            @Html.AntiForgeryToken()
        </form>
    </nav>
</div>

<div class="main-content">
    <div class="topbar">
        <span class="topbar-title">@ViewData["Title"]</span>
        <div class="d-flex align-items-center gap-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success py-1 px-3 mb-0 small">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger py-1 px-3 mb-0 small">@TempData["Error"]</div>
            }
            <ul class="navbar-nav me-3 mb-0" style="list-style: none;">
                @await Component.InvokeAsync("Notifications")
            </ul>
            <div class="d-flex align-items-center gap-2 border-end pe-3 me-2">
                <span class="text-dark fw-bold small">@User.Identity?.Name</span>
                <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                    <button type="submit" class="btn btn-sm btn-outline-danger border-0"><i class="fa-solid fa-power-off"></i></button>
                </form>
            </div>
            <span class="text-muted small"><i class="fa-regular fa-calendar me-1"></i>@DateTime.Now.ToString("dddd, dd MMM yyyy")</span>
        </div>
    </div>

    <div class="content-area">
        @RenderBody()
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
