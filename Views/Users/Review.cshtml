@model LMS.Models.UserViewModel
@{
    ViewData["Title"] = "Employee Onboarding";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header mb-4">
    <h2><i class="bi bi-person-check me-2 text-success"></i>User Onboarding</h2>
    <p>Review and assign organizational roles to <strong>@Model.FirstName @Model.LastName</strong></p>
</div>

<div class="row">
    <!-- Left: Profile Info -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body text-center p-4">
                <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3" style="width: 80px; height: 80px;">
                    <span class="fs-1 fw-bold text-primary">@Model.FirstName[0]</span>
                </div>
                <h4 class="fw-bold mb-1">@Model.FirstName @Model.LastName</h4>
                <p class="text-muted small mb-3">@Model.Email</p>
                
                <div class="list-group list-group-flush text-start border-top pt-3">
                    <div class="list-group-item bg-transparent px-0 border-0">
                        <small class="text-muted d-block">Employee Code</small>
                        <span class="fw-semibold">@(string.IsNullOrEmpty(Model.EmployeeCode) ? "Not Assigned" : Model.EmployeeCode)</span>
                    </div>
                    <div class="list-group-item bg-transparent px-0 border-0">
                        <small class="text-muted d-block">Phone Number</small>
                        <span class="fw-semibold">@(string.IsNullOrEmpty(Model.Phone) ? "Not Provided" : Model.Phone)</span>
                    </div>
                    <div class="list-group-item bg-transparent px-0 border-0">
                        <small class="text-muted d-block">Preferred Shift</small>
                        <span class="badge bg-info bg-opacity-10 text-info">@Model.Shift</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Assignment Form -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="fw-bold mb-0">Role & Hierarchy Assignment</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="Review" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="FirstName" />
                    <input type="hidden" asp-for="LastName" />
                    <input type="hidden" asp-for="Email" />

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label fw-bold">System Role <span class="text-danger">*</span></label>
                            <select asp-for="Role" class="form-select border-primary" asp-items="@(new SelectList(ViewBag.Roles))" required></select>
                            <div class="form-text">Primary access level in the system</div>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="DepartmentId" class="form-label fw-bold">Department</label>
                            <select asp-for="DepartmentId" class="form-select" asp-items="@(new SelectList(ViewBag.Departments, "Id", "Name"))">
                                <option value="">-- Select Department --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="TeamId" class="form-label fw-bold">Operational Team</label>
                            <select asp-for="TeamId" class="form-select" asp-items="@(new SelectList(ViewBag.Teams, "Id", "Name"))">
                                <option value="">-- Select Team --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ManagerId" class="form-label fw-bold">Reporting Manager</label>
                        <select asp-for="ManagerId" class="form-select" asp-items="@(new SelectList(ViewBag.Managers, "Id", "Email"))">
                            <option value="">-- Select Manager --</option>
                        </select>
                        <div class="form-text text-muted italic small"><i class="bi bi-info-circle me-1"></i> The assigned manager will receive and review leave requests from this user.</div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Pending" class="btn btn-outline-secondary px-4">Save for Later</a>
                        <button type="submit" class="btn btn-success px-5 fw-bold shadow-sm">
                            <i class="bi bi-check2-circle me-1"></i> Activate & Send Welcome
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
